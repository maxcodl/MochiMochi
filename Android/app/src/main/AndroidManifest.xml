<?xml version="1.0" encoding="utf-8"?>

<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name="com.kawai.mochi.StickerApplication"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        tools:ignore="GoogleAppIndexingWarning">
        <activity
            android:name="com.kawai.mochi.EntryActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Handles both direct taps and shares of sticker packs. We accept broadly
                 by file type here (filename-based filtering is unreliable - many apps,
                 including Telegram, don't expose the real filename to Android at all).
                 EntryActivity.looksLikeStickerPack() validates the actual contents after
                 receiving the file, and rejects anything that isn't a real pack. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:mimeType="application/zip" />
                <data android:mimeType="application/x-zip-compressed" />
                <data android:mimeType="application/octet-stream" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.kawai.mochi.StickerPackListActivity"
            android:exported="false" />
        <activity
            android:name="com.kawai.mochi.StickerPackDetailsActivity"
            android:exported="false"
            android:parentActivityName="com.kawai.mochi.StickerPackListActivity"
            tools:ignore="UnusedAttribute">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="com.kawai.mochi.StickerPackListActivity" />
        </activity>
        <activity
            android:name="com.kawai.mochi.StickerPackInfoActivity"
            android:exported="false"
            android:label="@string/title_activity_sticker_pack_info"
            android:parentActivityName="com.kawai.mochi.StickerPackDetailsActivity"
            tools:ignore="UnusedAttribute">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="com.kawai.mochi.StickerPackDetailsActivity" />
        </activity>
        <activity
            android:name="com.kawai.mochi.SettingsActivity"
            android:exported="false"
            android:label="Settings" />
        <activity
            android:name="com.kawai.mochi.EditStickerPackActivity"
            android:exported="false" />

        <activity
            android:name="com.kawai.mochi.MergeStickerPacksActivity"
            android:exported="false"
            android:label="@string/merge_packs_title"
            android:parentActivityName="com.kawai.mochi.StickerPackListActivity" />

        <activity
            android:name="com.kawai.mochi.TelegramImportActivity"
            android:exported="false"
            android:label="@string/telegram_import_title"
            android:parentActivityName="com.kawai.mochi.StickerPackListActivity" />

        <activity
            android:name="com.kawai.mochi.ConversionTasksActivity"
            android:exported="false"
            android:label="@string/telegram_conversion_tasks_title"
            android:parentActivityName="com.kawai.mochi.StickerPackListActivity" />

        <service
            android:name="com.kawai.mochi.TelegramConversionService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />


        <activity
            android:name="com.kawai.mochi.ImportIndividualStickerActivity"
            android:exported="true">
            <!-- Intent filter for .idwasticker files (Individual Stickers) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:host="*" />
                <data android:mimeType="*/*" />
                <data android:pathPattern=".*\\.idwasticker" />
            </intent-filter>
            <!-- Catch by MIME type for individual stickers -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/octet-stream" />
                <data android:mimeType="image/webp" />
            </intent-filter>
        </activity>

        <provider
            android:name="com.kawai.mochi.StickerContentProvider"
            android:authorities="${contentProviderAuthority}"
            android:enabled="true"
            android:exported="true"
            android:grantUriPermissions="true"
            android:readPermission="com.whatsapp.sticker.READ" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

    <queries>
        <package android:name="com.whatsapp" />
        <package android:name="com.whatsapp.w4b" />
    </queries>
</manifest>